tmux -L "$TMUX_NS" select-pane -t "$SESSION:segman".2
tmux -L "$TMUX_NS" send-keys -t "$SESSION:segman" "claude --dangerously-skip-permissions" C-m
tmux -L "$TMUX_NS" select-pane -t "$SESSION:segman".3
tmux -L "$TMUX_NS" send-keys -t "$SESSION:segman" "git status" C-m

# Focus + attach
tmux -L "$TMUX_NS" select-window -t "$SESSION:config"
exec tmux -L "$TMUX_NS" attach -t "$SESSION"
