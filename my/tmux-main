# Window 4: Writesys
tmux -L "$TMUX_NS" new-window -t "$SESSION" -n "writesys" -c "$HOME/src/worktree-writesys/14.writesys"
tmux -L "$TMUX_NS" split-window -h -t "$SESSION:writesys" -c "$HOME/src/worktree-writesys/14.writesys"
