tmux -L "$TMUX_NS" select-pane -t "$SESSION:writesys".3
tmux -L "$TMUX_NS" send-keys -t "$SESSION:writesys" "git status" C-m

# Window 5: Study
tmux -L "$TMUX_NS" new-window -t "$SESSION" -n "study" -c "$HOME/src/feathers/13.ean"
tmux -L "$TMUX_NS" select-pane -t "$SESSION:study".1
